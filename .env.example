# Content source: this repo (read by cici's GitHub provider at runtime)
CICI_REPO=metrue/blog

# Token with read+write on this PRIVATE repo. Used server-side to render the
# (public) site from private content, and by /editor to commit changes.
# Set in Vercel project env — never commit a real value.
CICI_TOKEN=

# NextAuth — GitHub OAuth for /editor sign-in
NEXTAUTH_SECRET=
NEXTAUTH_URL=https://blog.minghe.me
GITHUB_ID=
GITHUB_SECRET=
